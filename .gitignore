# =============================================================================
# Python
# =============================================================================

# Bytecode — generated by the interpreter, never belongs in version control.
# The cpython-310 and cpython-313 variants in this repo are from running the
# suite on different Python versions. Both should have been excluded from day 1.
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/

# =============================================================================
# Testing
# =============================================================================

# pytest cache — recreated on every run
.pytest_cache/

# Test artifacts — generated by the suite itself
screenshots/
logs/

# Coverage reports
.coverage
.coverage.*
htmlcov/
coverage.xml

# =============================================================================
# Environment & secrets
# =============================================================================

# Local environment variables — contains URLs, credentials, and secrets.
# NEVER commit this file. Use .env.example (no real values) as documentation.
.env
.env.local
.env.*.local

# Virtual environments
.venv/
venv/
env/

# =============================================================================
# IDE & editor
# =============================================================================

# PyCharm
.idea/

# VS Code — the settings folder can be committed if the team agrees on shared
# settings, but the default is to exclude it.
.vscode/

# =============================================================================
# Operating system
# =============================================================================

# macOS — Finder metadata written automatically on any macOS machine.
# Already committed to this repo; see cleanup instructions below.
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Cleanup: files already tracked that this file now excludes
# =============================================================================
# The entries above won't untrack files git already knows about.
# Run these commands once to remove them from the index (not from disk):
#
#   git rm -r --cached __pycache__/ .pytest_cache/ .DS_Store
#   git commit -m "chore: untrack python cache, pytest cache, and ds_store files"
#
# After that commit, git will ignore them going forward.
# The --cached flag removes them from tracking only — your local files are safe.